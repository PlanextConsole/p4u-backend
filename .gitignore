# Dependencies (all packages)
**/node_modules/

# Build outputs
**/dist/
**/dist-ssr/
**/build/
**/.next/
**/out/

# Env & secrets — commit only *.example
**/.env
**/.env.local
**/.env.*.local
**/.env.development.local
**/.env.production.local
# Keep examples trackable
!**/.env.example

# Uploads & runtime media (admin/vendor local disk)
**/uploads/
admin-management-services/uploads/

# Logs & debug
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test / coverage
**/coverage/
**/.nyc_output/
**/*.lcov

# Tooling cache
**/.vite/
**/.eslintcache
**/*.tsbuildinfo
.turbo/

# IDE / OS
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~
.DS_Store
Thumbs.db
Desktop.ini

# Cursor / local agent (optional)
.claude/

# Separate frontend repos (each has its own Git remote — do not track in p4u-backend)
p4u-admin-web/
p4u-new-user-web/
p4u-new-vendor-web/
