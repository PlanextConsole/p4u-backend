SERVER_PORT=8089
SERVICE_HOST=localhost
DISCOVERY_SERVICE_URL=http://localhost:8761
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root@123
DB_NAME=p4u_admin_db

# Keycloak JWT validation — issuer must match token `iss` (check with client_credentials curl).
KEYCLOAK_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=p4u-realm
JWT_ISSUER_URI=http://localhost:8180/realms/p4u-realm

# Production VPS — persistent upload storage (optional if uploads/ is symlinked to /opt/p4u/storage/vendor-uploads)
# UPLOAD_DIR=/opt/p4u/storage/vendor-uploads

# Razorpay — required for vendor plan purchases (Profile → Plans & Payments).
# Free plans (price 0) are assigned without these; paid plans need both.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
